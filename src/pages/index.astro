---
import Layout from "../layouts/Layout.astro";
import ContentCard from "../components/ContentCard.astro";
import { getCollection } from "astro:content";
import { bio } from "../data/bio";

const homepageSections = [
  {
    key: "applied-ai-agentic-systems",
    id: "ai-strategy",
    title: "Applied AI & Agentic Systems",
  },
  {
    key: "market-research-competitive-intelligence",
    id: "market-research",
    title: "Market Research & Competitive Intelligence",
  },
  {
    key: "developer-enablement-platform-strategy",
    id: "developer-enablement-platform-strategy",
    title: "Developer Enablement & Platform Strategy",
  },
  {
    key: "clarity-power-agency",
    id: "clarity-power-agency",
    title: "On Clarity, Power, and Agency",
  },
] as const;

const posts = await getCollection("blog");

const sectionsWithPosts = homepageSections.map((section) => ({
  ...section,
  posts: posts
    .filter((post) => post.data.homepage?.section === section.key)
    .sort(
      (a, b) =>
        (a.data.homepage?.order ?? Number.MAX_SAFE_INTEGER) -
        (b.data.homepage?.order ?? Number.MAX_SAFE_INTEGER)
    ),
}));
---

<Layout
  title="Home | Kurtis Kemple"
  description={bio.synopsis}
  image="/images/og/homepage.png"
  canonical="https://kurtiskemple.com/"
>
  <div class="container mx-auto px-4">
    <div class="mb-24 lg:mb-48">
      <div class="text-center">
        <h1 class="text-5xl lg:text-7xl mb-6">Hey, I'm Kurt.</h1>
        <p
          class="text-3xl lg:text-4xl mb-8 font-heading max-w-xl mx-auto"
          style="line-height: 1.15;"
        >
          <span>I'm a</span>
          <span class="text-honey-crusted-chicken">
            <a href="https://www.businessinsider.com/aws-jail-formerly-incarcrated-kurt-kemple-developer-advocate-2021-4" class="text-honey-crusted-chicken" target="_blank" rel="noopener noreferrer">formerly incarcerated</a>
          </span>
          <span>tech leader, <a href="/photography" class="text-honey-crusted-chicken">photographer</a>, creator, and</span>
          <span class="text-autumn-fire">advocate</span>
          <span>for second chances.</span>
          <span class="block text-base -rotate-2 mt-4 font-sans font-semibold"
            >(and lately I've been getting into some <span
              class="text-honey-crusted-chicken">theoretical</span> <span
              class="text-autumn-fire">physics</span
            > 😅)</span
          >
        </p>
      </div>
    </div>

    {
      sectionsWithPosts.map((section, index) => (
        <>
          <h3 class="text-4xl font-semibold mb-8 text-raptures-light" id={section.id}>
            {section.title}
          </h3>

          <div class="mb-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {section.posts.map((post) => (
              <ContentCard
                slug={`/blog/${post.slug}`}
                title={post.data.title}
                description={post.data.description}
              />
            ))}
          </div>

          {
            index < sectionsWithPosts.length - 1 && (
              <div class="my-24 flex justify-center">
                <div class="w-1/2 h-1 bg-honey-crusted-chicken rounded-full"></div>
              </div>
            )
          }
        </>
      ))
    }
  </div>
</Layout>
